{
  "workspace_root": "/tmp/workspace",
  "editable_paths": ["src/**"],
  "read_only_paths": ["data/**"],
  "eval_command": "python3 -c 'print(0.95)'",
  "eval_parser": "number",
  "primary_metric": "accuracy",
  "metric_direction": "maximize",
  "max_iterations": 3,
  "max_hours": 1,
  "stop_rule": {
    "metric_threshold": 0.9,
    "max_no_improvement_rounds": 1
  }
}
