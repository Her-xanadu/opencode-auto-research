FROM node:22-bookworm-slim

ENV PATH=/root/.opencode/bin:${PATH}

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates curl git python3 python3-pip unzip \
  && python3 -m pip install --break-system-packages --no-cache-dir --default-timeout=1000 "dvc>=3,<4" "dvclive>=3,<4" \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g opencode-ai@1.2.24 oh-my-opencode@3.11.2

WORKDIR /workspace

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

CMD ["bash", "/workspace/scripts/docker/run-opencode-kimi-smoke.sh"]
